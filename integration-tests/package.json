{
  "name": "@midnight/ledger-api-tests",
  "version": "0.0.1",
  "description": "Integration tests for Ledger API",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "author": "IOHK",
  "license": "Apache-2.0",
  "devEngines": {
    "packageManager": {
      "name": "yarn",
      "onFail": "error"
    }
  },
  "scripts": {
    "clean": "rm -rf dist node_modules reports lib-sources coverage logs",
    "build": "tsc",
    "local-prepare": "sudo rm -rf lib-sources && mkdir -p lib-sources && cp -r -L ../result/lib/node_modules/@midnight-ntwrk lib-sources",
    "test:coverage:prepare": "mkdir -p lib-sources && cp -r -L ../result/lib/node_modules/@midnight-ntwrk lib-sources",
    "test:coverage": "MN_AXIOS=true vitest run --config=vitest.config.coverage.ts",
    "test": "MN_AXIOS=true DEBUG='testcontainers:containers' vitest run",
    "test:wasm": "MN_WASM_PROVING=true MN_AXIOS=true DEBUG='testcontainers:containers' vitest run --config=vitest.config.wasm.ts",
    "test-proving": "MN_AXIOS=true DEBUG='testcontainers:containers' vitest run --dir='src/test/proving'",
    "test-no-proving": "MN_AXIOS=true DEBUG='testcontainers:containers' vitest run --dir='src/test/no-proving'",
    "test-security": "MN_AXIOS=true DEBUG='testcontainers:containers' vitest run --dir='src/test/security'",
    "test-docker": "docker compose -f proof-server.yml pull && yarn test",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "@midnight-ntwrk/ledger": "link:../result/lib/node_modules/@midnight-ntwrk/ledger-v8",
    "@midnight-ntwrk/zkir-v2": "link:../result/lib/node_modules/@midnight-ntwrk/zkir-v2"
  },
  "devDependencies": {
    "@d2t/vitest-ctrf-json-reporter": "1.3.0",
    "@dao-xyz/borsh": "5.2.4",
    "@eslint/compat": "1.4.1",
    "@tsconfig/node24": "24.0.4",
    "@types/eslint": "9.6.1",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "allure-commandline": "2.38.1",
    "allure-vitest": "3.7.1",
    "axios": "1.15.2",
    "axios-retry": "4.5.0",
    "cache-ts": "1.0.0",
    "cross-fetch": "4.1.0",
    "eslint": "9.39.4",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "fetch-retry": "6.0.0",
    "lodash": "4.18.1",
    "pino": "9.14.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "rxjs": "7.8.2",
    "testcontainers": "11.14.0",
    "typescript": "6.0.3",
    "vite-plugin-wasm": "3.6.0",
    "vitest": "3.2.4",
    "vitest-ctrf-json-reporter": "0.0.3"
  },
  "files": [
    "dist/"
  ],
  "packageManager": "yarn@4.14.1"
}
